#!/usr/bin/env ruby

ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../Gemfile", __dir__)
require "bundler/setup"

Dir.chdir(File.expand_path("..", __dir__)) do
  Process.exec "fd . | entr -rz env RACK_ENV=development PCELKA_PROCFILE=examples/procfile/Procfile bundle exec falcon serve --bind http://localhost:9292 -n 1"
end

